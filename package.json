{
  "name": "comments-api",
  "version": "1.0.0",
  "description": "A simple comments API",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "start": "docker-compose --env-file .env up",
    "build": "tsc",
    "build:watch": "tsc --watch",
    "type-check": "tsc --noEmit",
    "type-check:watch": "tsc --noEmit --watch",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:types": "tsc --noEmit && echo \"✓ Type checking passed\"",
    "dev": "tsx watch src/index.ts",
    "clean": "rimraf dist",
    "lint:types": "tsc --noEmit --pretty"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.11.0",
  "dependencies": {
    "@paralleldrive/cuid2": "^2.2.2",
    "axios": "^1.11.0",
    "dotenv": "^17.2.1",
    "h3": "^1.15.4",
    "ip-regex": "^5.0.0",
    "pg": "^8.16.3",
    "sanitize-html": "^2.17.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^24.3.0",
    "@types/pg": "^8.15.5",
    "@types/sanitize-html": "^2.16.0",
    "jest": "^30.0.5",
    "rimraf": "^6.0.1",
    "ts-jest": "^29.4.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
